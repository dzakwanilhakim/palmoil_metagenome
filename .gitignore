# --- targets pipeline cache (regenerable; can be large) ---
_targets/

# --- renv: ignore the library, KEEP renv.lock + settings ---
renv/library/
renv/local/
renv/cellar/
renv/staging/
renv/python/
renv/sandbox/
# (renv.lock and renv/activate.R + renv/settings.json are tracked)

# --- R session cruft ---
.Rhistory
.RData
.Rproj.user/
*.Rproj
.Ruserdata

# --- generated outputs (regenerable from the pipeline) ---
results/
data/processed/

# --- raw data (large; lives on /mnt or is delivered separately) ---
# Comment this out if you DO want raw data versioned.
data/raw/

# --- OS / editor noise ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*~